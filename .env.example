# ==============================================================================
# COMPASS RAG CONFIGURATION (ENVIRONMENT VARIABLES ONLY)
# ==============================================================================
# Every configuration value required by the application is listed below.
# Copy this file to `.env` before running locally: `cp .env.example .env`
# ZERO HARDCODED VALUES: All connection strings, model names, and thresholds
# MUST be configured via this file or environment variables in production.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. GENERAL SERVICE CONFIGURATION
# ------------------------------------------------------------------------------
# Environment name (e.g., development, staging, production)
ENVIRONMENT="development"

# Global log level for all services (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# Whether to output logs in structured JSON format (True/False).
# Set to True in production for logging aggregators (e.g., Elasticsearch/Datadog).
JSON_LOGS="True"

# ------------------------------------------------------------------------------
# 2. DATABASE & DATA STORE CONNECTION STRINGS
# ------------------------------------------------------------------------------
# PostgreSQL Data Source Name (asyncpg driver) for transactional/relational storage
POSTGRES_DSN="postgresql+asyncpg://postgres:postgres@localhost:5432/compass_rag"

# Redis URL for caching, rate limiting, and future asynchronous message queues
REDIS_URL="redis://localhost:6379/0"

# Qdrant vector database HTTP endpoint for dense/sparse embedding retrieval
QDRANT_URL="http://localhost:6333"

# Elasticsearch cluster URL for BM25 / keyword indexing and hybrid search
ELASTICSEARCH_URL="http://localhost:9200"

# ------------------------------------------------------------------------------
# 3. AI MODELS & EMBEDDINGS CONFIGURATION
# ------------------------------------------------------------------------------
# Embedding provider selection: 'local' (SentenceTransformer) or 'openai'
EMBEDDING_PROVIDER="local"

# Local SentenceTransformer embedding model name (produces 384-dim vectors by default)
LOCAL_EMBEDDING_MODEL="all-MiniLM-L6-v2"

# OpenAI embedding model name when provider is 'openai' (produces 1536-dim vectors)
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# OpenAI API key used when EMBEDDING_PROVIDER="openai"
OPENAI_API_KEY=""

# Embedding model name used for chunk indexing and query embedding
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"

# Dimension size of vector embeddings produced by the chosen model
EMBEDDING_DIMENSION="384"

# Primary Large Language Model used for final generation and self-correction reasoning
LLM_MODEL_NAME="gpt-4o-mini"

# ------------------------------------------------------------------------------
# 4. RAG PIPELINE & SELF-CORRECTION THRESHOLDS
# ------------------------------------------------------------------------------
# Minimum cosine similarity score (0.0 to 1.0) required to include a chunk from retrieval
SIMILARITY_THRESHOLD="0.75"

# Number of top candidate chunks to retrieve per search query
RETRIEVAL_TOP_K="10"

# Minimum confidence score (0.0 to 1.0) required for the self-correction evaluator to approve context
CORRECTION_CONFIDENCE_THRESHOLD="0.80"

# Reciprocal Rank Fusion k constant
RRF_K_CONSTANT="60"

# Reranker provider selection: 'local' (CrossEncoder) or 'cohere'
RERANKER_PROVIDER="local"

# Local CrossEncoder reranking model name
LOCAL_RERANK_MODEL="cross-encoder/ms-marco-MiniLM-L-6-v2"

# Cohere reranking model and API key when provider is 'cohere'
COHERE_RERANK_MODEL="rerank-english-v3.0"
COHERE_API_KEY=""

# Minimum average reranked score required for verified confidence status
RETRIEVAL_CONFIDENCE_THRESHOLD="0.70"

# Maximum number of query rewrite / self-correction attempts before falling back or failing
MAX_RETRIES="3"

# ------------------------------------------------------------------------------
# 5. SERVICE-TO-SERVICE HTTP COMMUNICATION URLS
# ------------------------------------------------------------------------------
# Internal base URL for the Ingestion service (port 8001)
INGESTION_SERVICE_URL="http://localhost:8001"

# Internal base URL for the Retrieval service (port 8002)
RETRIEVAL_SERVICE_URL="http://localhost:8002"

# Internal base URL for the Correction service (port 8003)
CORRECTION_SERVICE_URL="http://localhost:8003"

# Internal base URL for the Generation service (port 8004)
GENERATION_SERVICE_URL="http://localhost:8004"
